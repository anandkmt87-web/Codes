#include <bits/stdc++.h>
using namespace std;

int main() {
	// your code goes here
	int n , sum = 0;
	cin >> n ;
    vector<vector<int>> mat(n,vector<int>(n,0));
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < n; j++) {
            cin >> mat[i][j] ;
        }
    }
     for(int i = 0; i < n; i++) {
        for(int j = 0; j < n; j++) {
            if(i == 0 || i == n-1 || j == 0 || j == n-1) {
                sum += mat[i][j];
            }
        }
        
    }
    cout << sum << endl  ;
}
