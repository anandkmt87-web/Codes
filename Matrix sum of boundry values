#include <bits/stdc++.h>
using namespace std;

int sumOfBoundry(vector<vector<int>> &mat){
    int sum = 0;
    int n =mat.size();
     for(int i = 0; i < n; i++) {
        for(int j = 0; j < n; j++) {
            if(i == 0 || i == n-1 || j == 0 || j == n-1) {
                sum += mat[i][j];
            }
        }
        
    }
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < n; j++) {
            if(i == 0 || i == n-1 || j == 0 || j == n-1) {
                cout <<  mat[i][j] << " ";
            }
            else {
                cout << "  ";
            }
        }
        cout << endl;
        
    }
    cout << sum << endl  ;
}

int main() {
	// your code goes here
	int n ;
	cin >> n ;
    vector<vector<int>> mat(n,vector<int>(n,0));
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < n; j++) {
            cin >> mat[i][j] ;
        }
    }
    sumOfBoundry(mat);
    
}
